  "manifestURI": "https://raw.githubusercontent.com/Crashdaemon/Seanime-SeaStats/main/seastats.json",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": ["anilist", "anilist-token", "database", "storage"]
    }
  }
}
